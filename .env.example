# ─────────────────────────────────────────────────────────────
# RK University Admission Voice Assistant — environment config
# Copy this file to ".env" and fill in your keys.
# ─────────────────────────────────────────────────────────────

# Public base URL (your ngrok tunnel), no trailing slash.
# Example: https://rku-demo.ngrok-free.app
PUBLIC_URL=
PORT=3000

# ── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Bhashini (https://bhashini.gov.in / ULCA) ────────────────
# UDYAT key = the API key from your ULCA "User ID + ULCA API key" pair.
# Inference key = the "authorization" value returned by the pipeline config call.
BHASHINI_USER_ID=
BHASHINI_UDYAT_KEY=
BHASHINI_INFERENCE_KEY=
# ULCA pipeline id for MeitY (default works for gu<->en ASR/TTS/NMT)
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd

# ── LLM (Admission Knowledge Assistant) ──────────────────────
# Provider: "anthropic" | "openai" | "mock"
# "mock" needs no key — answers from the local course KB so you can demo offline.
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=
# For an OpenAI-compatible endpoint (vLLM, Together, local), set the base URL:
LLM_BASE_URL=

# ── Behaviour ────────────────────────────────────────────────
# Speech recognition for phone calls: "bhashini" (media-stream) or "twilio" (Gather).
STT_ENGINE=twilio
DEFAULT_LANGUAGE=gu

# ── Admin panel login (demo auth) ────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=rku123

# ── Sarvam AI (Bulbul) TTS — https://dashboard.sarvam.ai ─────
# Primary TTS engine (telephony-grade Gujarati). Falls back to Bhashini, then
# Twilio's Google gu-IN voice if unset.
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka      # female; alternatives: manisha, vidya, arya
SARVAM_TTS_PACE=1.0             # 0.9 slower, 1.1 faster
SARVAM_TTS_LOUDNESS=1.0
