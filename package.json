{
  "name": "rku-admission-voice-assistant",
  "version": "1.0.0",
  "description": "RK University Gujarati admission voice assistant — inbound/outbound calls via Twilio, Bhashini STT/TTS, LLM knowledge assistant.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "call": "node scripts/outbound-call.js",
    "tunnel": "ngrok start rku"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "twilio": "^5.3.0",
    "wavefile": "^11.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}
